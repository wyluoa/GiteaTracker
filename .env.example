# Copy this file to .env and adjust for your environment.
# .env should NOT be committed to version control.

# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=1

# Server
HOST=127.0.0.1
PORT=5000

# Path prefix for reverse proxy (e.g. Traefik).
# Example: BASE_URL=/GiteaTracker  →  http://host:port/GiteaTracker/
# Leave empty for root deployment.
BASE_URL=

# Database
# DB_PATH=/var/lib/gitea-tracker/gitea_tracker.db

# Attachments
# ATTACHMENT_DIR=/var/lib/gitea-tracker/attachments
ATTACHMENT_MAX_MB=5

# Session
SESSION_HOURS=24
